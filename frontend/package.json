{
  "name": "indicadores-folha-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "demo": "cross-env VITE_DEMO_MODE=true vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:demo": "cross-env VITE_DEMO_MODE=true npm run build",
    "desktop:dev": "concurrently -k \"cross-env VITE_DEMO_MODE=true vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 node electron/dev-launch.cjs\"",
    "desktop:build": "cross-env VITE_DEMO_MODE=true npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "br.com.indicadoresfolha.demo",
    "productName": "Sistema Indicadores de Folha - Demo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Sistema-Indicadores-de-Folha-Demo-${version}-Portable.${ext}"
    }
  }
}
